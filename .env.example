# Скопируй в .env и заполни. Никогда не коммить .env.
# US-резидентный прокси (рекомендую BrightData / SmartProxy / SOAX residential pool).
PROXY_SERVER=http://us-residential.example.com:8000
PROXY_USER=your_user
PROXY_PASS=your_pass

# (опционально) сервисный аккаунт Google для записи в Sheets
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json
GOOGLE_SHEET_ID=1abcDEF...your_sheet_id
